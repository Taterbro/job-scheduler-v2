{
    "swagger": "2.0",
    "info": {
        "contact": {}
    },
    "paths": {
        "/jobs": {
            "post": {
                "description": "Creates a new job that will be queued, scheduled, and processed by workers. Supports immediate, scheduled, recurring, and DAG-dependent jobs.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "text/plain"
                ],
                "tags": [
                    "jobs"
                ],
                "summary": "Create a new background job",
                "parameters": [
                    {
                        "description": "Job creation payload",
                        "name": "job",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/job.Job"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Job created: {job-id}",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "400": {
                        "description": "Invalid JSON payload",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/jobs/list": {
            "get": {
                "description": "Returns all jobs in the system with their current status, useful for live monitoring (polling).",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "jobs"
                ],
                "summary": "List all jobs",
                "responses": {
                    "200": {
                        "description": "List of all jobs",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/job.Job"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "job.Job": {
            "type": "object"
        },
        "job.Priority": {
            "type": "integer",
            "enum": [
                1,
                2,
                3
            ],
            "x-enum-varnames": [
                "PriorityHigh",
                "PriorityMedium",
                "PriorityLow"
            ]
        }
    }
}